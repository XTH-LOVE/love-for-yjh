                background: 'transparent', border: 'none', cursor: 'pointer',
                color: 'rgba(255,180,210,0.7)', fontSize: 14,
                transition: 'color 0.3s',
              }}
            >
              {isRegister ? '已有账号？去登录 ✨' : '没有账号？去注册 ✨'}
            </button>
          </div>
        </div>

        {/* 底部装饰 */}
        <div style={{
          textAlign: 'center', marginTop: 24,
          color: 'rgba(255,200,220,0.35)', fontSize: 12, letterSpacing: 1,
        }}>
          Made with 💖 for 阳婧欢
        </div>
      </div>
    </div>
  );
}

/* ================================================================
   MAIN LAYOUT
   ================================================================ */
function MainLayout() {
  const [user, setUser] = useState<any>(null);
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);
  const [isMobile, setIsMobile] = useState(window.innerWidth < 768);
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);
  const navigate = useNavigate();
  const location = useLocation();
  const avatarEmoji = ['😊', '🥰', '😍', '💕', '🌸'][user?.id % 5] || '😊';

  useEffect(() => {
    const saved = localStorage.getItem('user');
    if (saved) setUser(JSON.parse(saved));
    const handler = () => setIsMobile(window.innerWidth < 768);
    window.addEventListener('resize', handler);
    return () => window.removeEventListener('resize', handler);
  }, []);

  const handleLogout = () => {
    localStorage.removeItem('token');
    localStorage.removeItem('user');
    navigate('/login', { replace: true });
    message.success('下次再见，带着爱离开 💕');
  };

  const menuItems = [
    { key: '/', icon: '🏠', label: '爱的主页' },
    { key: '/sweet', icon: '💌', label: '甜蜜时光' },
    { key: '/record', icon: '📖', label: '记录时光' },
    { key: '/photos', icon: '📸', label: '我们的回忆' },
    { key: '/videos', icon: '🎬', label: '爱的影集' },
    { key: '/fun', icon: '🎯', label: '趣味时光' },
    { key: '/memory', icon: '🧩', label: '记忆乐园' },
    { key: '/profile', icon: '👤', label: '个人中心' },
  ];

  const getActiveKey = () => {
    const path = location.pathname;
    if (path === '/') return '/';
    return menuItems.find((m) => m.key !== '/' && path.startsWith(m.key))?.key || '/';
  };

  const activeKey = getActiveKey();

  const sidebarContent = (
    <div style={{ display: 'flex', flexDirection: 'column', height: '100%', padding: '0 8px' }}>
      <div style={{ padding: '28px 16px 20px', textAlign: 'center', borderBottom: '1px solid rgba(255,255,255,0.1)', marginBottom: 8 }}>
        <div style={{ fontSize: 36, animation: 'heartBeat 3s ease-in-out infinite', marginBottom: 8 }}>💖</div>
        {!sidebarCollapsed && (
          <>
            <div style={{ color: '#fff', fontSize: 14, fontWeight: 700 }}>缐廷华 💕 阳婧欢</div>
            <div style={{ color: 'rgba(255,220,235,0.6)', fontSize: 12, marginTop: 4 }}>
              {user?.nickname || '我们的爱情故事'}
            </div>
          </>
        )}
      </div>

      <div style={{ flex: 1, paddingTop: 8 }}>
        {menuItems.map((item) => (
          <div
            key={item.key}
            className={`sidebar-item ${activeKey === item.key ? 'sidebar-item-active' : ''}`}
            onClick={() => { navigate(item.key); setMobileMenuOpen(false); }}
          >
            <span style={{ fontSize: 20, minWidth: 24, textAlign: 'center' }}>{item.icon}</span>
            {!sidebarCollapsed && <span style={{ fontSize: 14 }}>{item.label}</span>}
          </div>
        ))}
      </div>

      <div style={{ padding: '8px 0 16px', borderTop: '1px solid rgba(255,255,255,0.1)' }}>
        {!isMobile && (
          <div
            className="sidebar-item"
            onClick={() => setSidebarCollapsed(!sidebarCollapsed)}
            style={{ justifyContent: sidebarCollapsed ? 'center' : 'flex-start' }}
          >
            <span style={{ fontSize: 18 }}>{sidebarCollapsed ? '→' : '←'}</span>
            {!sidebarCollapsed && <span style={{ fontSize: 13 }}>收起侧栏</span>}
          </div>
        )}
        <div
          className="sidebar-item"
          onClick={handleLogout}
          style={{ color: 'rgba(255,200,210,0.7)', justifyContent: sidebarCollapsed ? 'center' : 'flex-start' }}
        >
          <LogoutOutlined style={{ fontSize: 18 }} />
          {!sidebarCollapsed && <span style={{ fontSize: 13 }}>退出登录</span>}
        </div>
      </div>
    </div>
  );

  const sidebarWidth = isMobile ? 0 : (sidebarCollapsed ? 64 : 220);

  return (
    <div style={{ display: 'flex', minHeight: '100vh' }}>
      {!isMobile && (
        <div style={{
          width: sidebarCollapsed ? 64 : 220,
          minHeight: '100vh',
          background: 'linear-gradient(180deg, #c2185b 0%, #880e4f 50%, #6a0f42 100%)',
          position: 'fixed', left: 0, top: 0, bottom: 0, zIndex: 100,
          transition: 'width 0.3s cubic-bezier(0.34, 1.3, 0.64, 1)',
          overflow: 'hidden',
          boxShadow: '4px 0 24px rgba(194,24,91,0.25)',
        }}>
          {sidebarContent}
        </div>
      )}

      {isMobile && (
        <Modal
          open={mobileMenuOpen}
          onCancel={() => setMobileMenuOpen(false)}
          footer={null}
          closable={false}
          width={260}
          style={{ top: 50, left: 0, margin: 0 }}
          styles={{ body: { padding: 0, background: 'linear-gradient(180deg, #c2185b 0%, #880e4f 100%)', borderRadius: 20, overflow: 'hidden', minHeight: 480 } }}
        >
          {sidebarContent}
        </Modal>
      )}

      <div style={{ flex: 1, marginLeft: sidebarWidth, transition: 'margin-left 0.3s', minHeight: '100vh', display: 'flex', flexDirection: 'column' }}>
        <div style={{
          background: 'rgba(255,255,255,0.88)',
          backdropFilter: 'blur(12px)',
          WebkitBackdropFilter: 'blur(12px)',
          padding: '0 24px',
          height: 60,
          display: 'flex', alignItems: 'center', justifyContent: 'space-between',
          boxShadow: '0 2px 16px rgba(255,45,120,0.08)',
          position: 'sticky', top: 0, zIndex: 99,
          borderBottom: '1px solid rgba(255,192,203,0.2)',
        }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
            {isMobile && (
              <button
                onClick={() => setMobileMenuOpen(true)}
                style={{ border: 'none', background: 'transparent', fontSize: 22, cursor: 'pointer', color: '#e91e63', padding: 4 }}
              >
                ☰
              </button>
            )}
            <HeartOutlined style={{ color: '#ff2d78', fontSize: 20, animation: 'heartBeat 3s ease-in-out infinite' }} />
            <span style={{ fontSize: 17, fontWeight: 800, background: 'var(--gradient-love)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent', backgroundClip: 'text', letterSpacing: 1 }}>
              缐廷华 💕 阳婧欢
            </span>
          </div>
          <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
            {!isMobile && (
              <div style={{ width: 280 }}>
                <WeatherWidget />
              </div>
            )}
            <span style={{ color: '#888', fontSize: 13 }}>{user?.nickname || user?.username}</span>
            <div
              style={{
                width: 36, height: 36, borderRadius: '50%',
                background: 'var(--gradient-love)',
                display: 'flex', alignItems: 'center', justifyContent: 'center',
                cursor: 'pointer', fontSize: 16,
                boxShadow: '0 2px 12px rgba(255,45,120,0.3)',
              }}
              onClick={() => navigate('/profile')}
              title="个人中心"
            >
              {avatarEmoji}
            </div>
          </div>
        </div>

        <div style={{ flex: 1, padding: isMobile ? '16px 12px' : '24px', overflowY: 'auto' }}>
          <Routes>
            <Route path="/" element={<HomePage user={user} />} />
            <Route path="/sweet" element={<SweetMomentsPage />} />
            <Route path="/record" element={<RecordTimePage />} />
            <Route path="/fun" element={<FunTimePage />} />
            <Route path="/memory" element={<MatchTestPage />} />
            <Route path="/photos" element={<PhotosPage />} />
            <Route path="/videos" element={<VideosPage />} />
            <Route path="/map" element={<MapPage />} />
            <Route path="/achievements" element={<AchievementPage />} />
            <Route path="/anniversary" element={<AnniversaryPage />} />
            <Route path="/profile" element={<ProfilePage user={user} setUser={setUser} />} />
          </Routes>
        </div>
      </div>

    </div>
  );
}

/* ================================================================
   Real-time Counter Hook
   ================================================================ */
function useLiveCounter(startDate: string) {
  const [now, setNow] = useState(dayjs());
  useEffect(() => {
    const timer = setInterval(() => setNow(dayjs()), 1000);
    return () => clearInterval(timer);
  }, []);
  const start = dayjs(startDate);
  const diff = dayjs.duration(now.diff(start));
  return {
    days: Math.floor(diff.asDays()),
    hours: diff.hours(),
    minutes: diff.minutes(),
    seconds: diff.seconds(),
    totalSeconds: Math.floor(diff.asSeconds()),
  };
}

/* ================================================================
   HOME PAGE — 极简浪漫首页 v3.0
   ================================================================ */
function HomePage({ user }: { user: any }) {
  const [note, setNote] = useState('');
  const [loadingNote, setLoadingNote] = useState(false);
  const [recentPhotos, setRecentPhotos] = useState<any[]>([]);
  const [previewImg, setPreviewImg] = useState('');
  const [previewOpen, setPreviewOpen] = useState(false);
  const [nextAnniversary, setNextAnniversary] = useState<{name: string; days: number} | null>(null);
  const [showWhisper, setShowWhisper] = useState(false);
  const [whisperText, setWhisperText] = useState('');
  const [sendingWhisper, setSendingWhisper] = useState(false);
  const clickEffects = useClickHeart();
  const mouseTrail = useMouseTrail();
  const fullScreenHearts = useFullScreenHearts();
  const navigate = useNavigate();
  const counter = useLiveCounter('2026-01-14');

  // 根据天数获取光环颜色
  const getAuraColor = (days: number) => {
    if (days >= 365) return 'linear-gradient(135deg, #ff6b9d, #a855f7, #ec4899, #f59e0b, #3b82f6, #ff6b9d)'; // 彩虹
    if (days >= 100) return 'linear-gradient(135deg, #f59e0b, #fbbf24, #fcd34d)'; // 金色
    return 'linear-gradient(135deg, #ff6b9d, #ff8fab, #ffbdd5)'; // 粉色
  };

  const auraAnimation = counter.days >= 365 ? 'rainbowRotate 3s linear infinite' : 'glowRotate 3s ease-in-out infinite';

  const loadNote = useCallback(async () => {
    setLoadingNote(true);
    try {
      const res = await apiFetch('/love/random-note');
      if (res.code === 200 && res.data) {
        setNote(res.data.content);
      } else {
        setNote(STATIC_NOTES[Math.floor(Math.random() * STATIC_NOTES.length)].content);
      }
    } catch {
      setNote(STATIC_NOTES[Math.floor(Math.random() * STATIC_NOTES.length)].content);
    }
    setLoadingNote(false);
  }, []);

  useEffect(() => {
    loadNote();
    (async () => {
      try {
        const [photosRes, annivRes] = await Promise.all([apiFetch('/photos'), apiFetch('/love/anniversaries')]);
        if (photosRes.code === 200 && photosRes.data?.length > 0) {
          setRecentPhotos(photosRes.data.slice(0, 6));
        }
        if (annivRes.code === 200 && annivRes.data?.length > 0) {
          const today = dayjs();
          const upcoming = annivRes.data
            .map((a: any) => {
              let target = dayjs(a.date);
              if (target.isBefore(today) || target.isSame(today, 'day')) target = target.add(1, 'year');
              return { ...a, targetDate: target };
            })
            .filter((a: any) => a.targetDate.diff(today, 'day') <= 365)
            .sort((a: any, b: any) => a.targetDate.diff(today) - b.targetDate.diff(today));
          if (upcoming.length > 0) {
            setNextAnniversary({ name: upcoming[0].title, days: upcoming[0].targetDate.diff(today, 'day') });
          }
        }
      } catch {}
    })();
  }, [loadNote]);

  const handleSendWhisper = async () => {
    if (!whisperText.trim()) return;
    setSendingWhisper(true);
    try {
      const res = await apiFetch('/whispers', { method: 'POST', body: JSON.stringify({ content: whisperText }) });
      if (res.code === 200 || res.code === 201) {
        message.success('💌 悄悄话已送达！');
        setWhisperText('');
        setShowWhisper(false);
      } else {
        message.error(res.message || '发送失败');
      }
    } catch {
      message.error('发送失败，请重试');
    }
    setSendingWhisper(false);
  };

  const pad = (n: number) => String(n).padStart(2, '0');

  // 双人头像
  const myAvatar = user?.avatar ? (user.avatar.startsWith('/') ? user.avatar : `/api/auth/avatar/${user.avatar}`) : null;
  const partnerAvatar = user?.partner_avatar ? (user.partner_avatar.startsWith('/') ? user.partner_avatar : `/api/auth/avatar/${user.partner_avatar}`) : null;
  const avatarEmojis = ['😊', '🥰', '😍', '💕', '🌸'];
  const partnerEmojis = ['😎', '🤗', '😘', '🥰', '😚'];
  const myEmoji = avatarEmojis[user?.id % 5] || '😊';
  const partnerEmoji = partnerEmojis[user?.id % 5] || '🥰';

  // 添加自定义样式
  const customStyles = `
    @keyframes glowRotate {
      0%, 100% { filter: hue-rotate(0deg) drop-shadow(0 0 15px rgba(255,107,157,0.6)); }
      50% { filter: hue-rotate(15deg) drop-shadow(0 0 25px rgba(255,107,157,0.9)); }
    }
    @keyframes rainbowRotate {
      0% { filter: hue-rotate(0deg) drop-shadow(0 0 20px rgba(255,107,157,0.8)); }
      100% { filter: hue-rotate(360deg) drop-shadow(0 0 20px rgba(168,85,247,0.8)); }
    }
    @keyframes gentleFloat {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-8px); }
    }
    .avatar-float { animation: gentleFloat 3s ease-in-out infinite; }
    .avatar-glow { animation: ${auraAnimation}; }
    .avatar-ring {
      position: absolute;
      inset: -8px;
      border-radius: 50%;
      background: ${getAuraColor(counter.days)};
      background-size: 400% 400%;
      z-index: -1;
      animation: ${auraAnimation};
    }
    .avatar-container {
      position: relative;
      animation: gentleFloat 3s ease-in-out infinite;
    }
    .avatar-container:nth-child(2) { animation-delay: 0.5s; }
    .avatar-container:nth-child(4) { animation-delay: 1s; }
    .time-unit-glow {
      position: relative;
      padding: 12px 16px;
      border-radius: 16px;
      background: rgba(255,255,255,0.9);
      box-shadow: 0 4px 20px rgba(255,107,157,0.2);
    }
    .time-unit-glow::before {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 18px;
      background: var(--gradient-love);
      z-index: -1;
      opacity: 0.5;
      animation: neonPulse 2s ease-in-out infinite;
    }
    .whisper-fab {
      position: fixed;
      bottom: 90px;
      right: 24px;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--gradient-love);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      box-shadow: 0 6px 24px rgba(255,45,120,0.4);
      z-index: 100;
      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .whisper-fab:hover {
      transform: scale(1.1) translateY(-4px);
      box-shadow: 0 10px 32px rgba(255,45,120,0.5);
    }
    .whisper-hint {
      position: fixed;
      bottom: 160px;
      right: 24px;
      background: rgba(255,255,255,0.95);
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 12px;
      color: #888;
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      z-index: 99;
      animation: fadeInUp 0.5s ease;
    }
    @keyframes spinHeart {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    .spinning-heart {
      position: absolute;
      font-size: 16px;
      animation: spinHeart 4s linear infinite;
    }
  `;

  return (
    <div className="page-enter">
      <style>{customStyles}</style>
      <FloatingHearts />
      {clickEffects}
      {mouseTrail}
      {fullScreenHearts}

      {/* 双人头像 + 主标题区 */}
      <div className="hero-banner" style={{ animation: 'fadeInUp 0.6s ease', textAlign: 'center' }}>
        {/* 双人头像展示 - 增强版 */}
        <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', marginBottom: 20, gap: 8 }}>
          {/* 我的头像 */}
          <div className="avatar-container">
            <div className="avatar-ring" />
            <div style={{
              width: 120, height: 120, borderRadius: '50%',
              background: myAvatar ? 'transparent' : 'var(--gradient-love)',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              fontSize: 56, boxShadow: '0 8px 32px rgba(255,45,120,0.4)',
              border: '5px solid #fff', overflow: 'hidden', zIndex: 2,
              position: 'relative',
            }}>
              {myAvatar ? <img src={myAvatar} alt="我" style={{ width: '100%', height: '100%', objectFit: 'cover' }} /> : myEmoji}
            </div>
          </div>

          {/* 爱心连接 - 旋转光环 */}
          <div style={{
            position: 'relative',
            width: 50, height: 50, borderRadius: '50%',
            background: 'var(--gradient-love)',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            fontSize: 24, boxShadow: '0 4px 20px rgba(255,45,120,0.5)',
            border: '4px solid #fff', zIndex: 3,
            margin: '0 -4px',
          }}>
            💕
            <span className="spinning-heart" style={{ position: 'absolute', top: -8, left: '50%', transform: 'translateX(-50%)' }}>✨</span>
            <span className="spinning-heart" style={{ position: 'absolute', bottom: -8, left: '50%', transform: 'translateX(-50%)', animationDirection: 'reverse' }}>✨</span>
          </div>

          {/* TA的头像 */}
          <div className="avatar-container">
            <div className="avatar-ring" style={{ background: 'linear-gradient(135deg, #a855f7, #ec4899, #a855f7)' }} />
            <div style={{
              width: 120, height: 120, borderRadius: '50%',
              background: partnerAvatar ? 'transparent' : 'linear-gradient(135deg, #a855f7, #ec4899)',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              fontSize: 56, boxShadow: '0 8px 32px rgba(168,85,247,0.4)',
              border: '5px solid #fff', overflow: 'hidden', zIndex: 2,
              position: 'relative',
            }}>
              {partnerAvatar ? <img src={partnerAvatar} alt="TA" style={{ width: '100%', height: '100%', objectFit: 'cover' }} /> : (user?.partner_name?.[0] || partnerEmoji)}
            </div>
          </div>
        </div>

        {/* 合并的名字显示 */}
        <div style={{
          display: 'inline-flex', alignItems: 'center', gap: 8,
          padding: '8px 24px', borderRadius: 50,
          background: 'rgba(255,255,255,0.8)',
          border: '2px solid rgba(255,107,157,0.3)',
          marginBottom: 12, fontSize: 18, fontWeight: 700,
        }}>
          <span style={{ color: '#e91e63' }}>{user?.nickname || '缐廷华'}</span>
          <span style={{ color: '#ff6b9d', fontSize: 20 }}>💕</span>
          <span style={{ color: '#a855f7' }}>{user?.partner_name || '阳婧欢'}</span>
        </div>

        <h1 className="love-title" style={{ marginBottom: 4 }}>💖 永远在一起 💖</h1>
        <p style={{ fontSize: 14, color: '#e91e63', fontWeight: 500, margin: 0 }}>
          在一起 {counter.days} 天 · 按 L 键满屏爱心 💕
        </p>
      </div>

      {/* 倒计时 - 增强版 */}
      <div className="love-card" style={{ marginBottom: 20, animation: 'fadeInUp 0.8s ease', textAlign: 'center' }}>
        <div style={{ fontSize: 13, color: '#aaa', marginBottom: 16, letterSpacing: 2 }}>💞 我们已经在一起</div>
        <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
          {[
            { val: counter.days, label: '天', glow: true },
            { val: pad(counter.hours), label: '时', glow: false },
            { val: pad(counter.minutes), label: '分', glow: false },
            { val: pad(counter.seconds), label: '秒', glow: true },
          ].map((t, i) => (
            <React.Fragment key={i}>
              <div className={t.glow ? 'time-unit-glow' : 'time-unit'} style={t.glow ? {} : {}}>
                <div className="time-value" style={t.glow ? { fontSize: 36 } : {}}>{t.val}</div>
                <div className="time-label">{t.label}</div>
              </div>
              {i < 3 && <div className="time-sep" style={{ fontSize: 32 }}>:</div>}
            </React.Fragment>
          ))}
        </div>
        <div style={{ marginTop: 16 }}>
          <span className="love-badge">❤️ 从 2026年01月14日 起</span>
          {counter.days >= 365 && <span className="love-badge" style={{ marginLeft: 8, background: 'linear-gradient(135deg, #f59e0b, #fbbf24)', color: '#fff' }}>🎉 一周年达成</span>}
          {counter.days >= 100 && counter.days < 365 && <span className="love-badge" style={{ marginLeft: 8, background: 'linear-gradient(135deg, #fbbf24, #f59e0b)', color: '#fff' }}>💯 百日纪念</span>}
        </div>
      </div>

      {/* 纪念日提醒 */}
      {nextAnniversary && (
        <div className="love-card" style={{
          marginBottom: 20, animation: 'fadeInUp 0.9s ease',
          textAlign: 'center', cursor: 'pointer',
        }} onClick={() => navigate('/anniversary')}>
          <div style={{ fontSize: 13, color: '#999', marginBottom: 6 }}>📅 下一个纪念日</div>
          <div style={{ fontSize: 18, fontWeight: 700, color: '#ff6b9d' }}>{nextAnniversary.name}</div>
          <div style={{ fontSize: 28, fontWeight: 900, color: '#ff6b9d', margin: '4px 0' }}>
            {nextAnniversary.days === 0 ? '今天就是这一天！🎉' : `还有 ${nextAnniversary.days} 天`}
          </div>
        </div>
      )}

      {/* 今日情话 */}
      <div className="love-card" style={{ marginBottom: 20, animation: 'fadeInUp 1s ease' }}>
        <div style={{ textAlign: 'center', marginBottom: 16 }}>
          <span style={{ fontSize: 22 }}>💗</span>
          <span style={{ fontSize: 17, fontWeight: 700, color: '#e91e63', marginLeft: 8 }}>今日情话</span>
        </div>
        <div style={{
          minHeight: 72, display: 'flex', alignItems: 'center', justifyContent: 'center',
          padding: '16px 24px',
          background: 'linear-gradient(135deg, rgba(255,240,246,0.8), rgba(255,220,235,0.5))',
          borderRadius: 16, border: '1px solid rgba(255,107,157,0.15)',
          position: 'relative',
        }}>
          <span style={{ position: 'absolute', top: 4, left: 12, fontSize: 40, color: 'rgba(255,107,157,0.15)', fontFamily: 'Georgia', lineHeight: 1 }}>"</span>
          <Typography.Text style={{ fontSize: 17, lineHeight: 1.9, color: '#555', textAlign: 'center', fontWeight: 500, fontStyle: 'italic', zIndex: 1, position: 'relative' }}>
            {note || '正在为你准备最甜蜜的情话...'}
          </Typography.Text>
          <span style={{ position: 'absolute', bottom: 4, right: 12, fontSize: 40, color: 'rgba(255,107,157,0.15)', fontFamily: 'Georgia', lineHeight: 1 }}>"</span>
        </div>
        <div style={{ textAlign: 'center', marginTop: 16 }}>
          <button className="love-btn love-btn-primary" onClick={loadNote} style={{ fontSize: 14 }}>
            {loadingNote ? '🔄 加载中...' : '🔀 换一句情话'}
          </button>
        </div>
      </div>

      {/* 照片墙 */}
      <div className="love-card" style={{ animation: 'fadeInUp 1.1s ease' }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16 }}>
          <div>
            <span style={{ fontSize: 22 }}>📸</span>
            <span style={{ fontSize: 17, fontWeight: 700, color: '#e91e63', marginLeft: 8 }}>我们的回忆</span>
            {recentPhotos.length > 0 && (
              <span style={{ marginLeft: 8, fontSize: 12, color: '#bbb' }}>({recentPhotos.length})</span>
            )}
          </div>
          <button className="love-btn love-btn-ghost" style={{ fontSize: 13, padding: '8px 18px' }} onClick={() => navigate('/photos')}>
            {recentPhotos.length > 0 ? '查看全部 →' : '去上传 →'}
          </button>
        </div>
        {recentPhotos.length === 0 ? (
          <div
            style={{
              textAlign: 'center', padding: '48px 20px',
              borderRadius: 16, border: '2px dashed rgba(255,107,157,0.35)',
              background: 'linear-gradient(135deg, rgba(255,240,246,0.6), rgba(255,220,235,0.3))',
              cursor: 'pointer', transition: 'all 0.3s',
            }}
            onClick={() => navigate('/photos')}
            onMouseOver={(e) => {
              e.currentTarget.style.borderColor = 'rgba(255,107,157,0.6)';
              e.currentTarget.style.background = 'linear-gradient(135deg, rgba(255,240,246,0.9), rgba(255,220,235,0.6))';
            }}
            onMouseOut={(e) => {
              e.currentTarget.style.borderColor = 'rgba(255,107,157,0.35)';
              e.currentTarget.style.background = 'linear-gradient(135deg, rgba(255,240,246,0.6), rgba(255,220,235,0.3))';
            }}
          >
            <div style={{ fontSize: 56, marginBottom: 12 }}>📷</div>
            <div style={{ color: '#e91e63', fontWeight: 700, fontSize: 16, marginBottom: 6 }}>还没有回忆</div>
            <div style={{ color: '#999', fontSize: 14 }}>点击前往「我们的回忆」上传照片</div>
          </div>
        ) : (
          <Row gutter={[10, 10]}>
            {recentPhotos.map((photo: any) => (
              <Col span={8} key={photo.id}>
                <div
                  className="photo-item"
                  onClick={() => { setPreviewImg(`/api/photos/file/${photo.filename}`); setPreviewOpen(true); }}
                  style={{ borderRadius: 12, overflow: 'hidden' }}
                >
                  <img src={`/api/photos/file/${photo.filename}`} alt="memory" style={{ width: '100%', aspectRatio: '1', objectFit: 'cover', display: 'block' }} loading="lazy" />
                  <div className="photo-overlay" style={{ borderRadius: 12 }}>
                    <div style={{ color: 'rgba(255,255,255,0.8)', fontSize: 11 }}>{dayjs(photo.created_at).format('MM-DD')}</div>
                  </div>
                </div>
              </Col>
            ))}
          </Row>
        )}
      </div>

      <Modal open={previewOpen} footer={null} onCancel={() => setPreviewOpen(false)} centered width="auto"
        styles={{ body: { padding: 0, background: 'transparent', textAlign: 'center' } }} style={{ maxWidth: '95vw' }}>
        <img src={previewImg} alt="preview" style={{ maxWidth: '92vw', maxHeight: '88vh', borderRadius: 16, display: 'block' }} />
      </Modal>

      {/* 悬浮悄悄话按钮 */}
      <button className="whisper-fab" onClick={() => setShowWhisper(true)}>
        💌
      </button>
      <div className="whisper-hint">给TA说悄悄话</div>

      {/* 悄悄话弹窗 */}
      <Modal
        open={showWhisper}
        onCancel={() => setShowWhisper(false)}
        footer={null}
        centered
        title={<span style={{ color: '#e91e63', fontWeight: 700 }}>💌 说悄悄话</span>}
        styles={{ body: { padding: '20px' } }}
      >
        <div style={{ textAlign: 'center', marginBottom: 16 }}>
          <div style={{ fontSize: 48, marginBottom: 8 }}>💕</div>
          <p style={{ color: '#888', fontSize: 14 }}>写下你想对 TA 说的话</p>
        </div>
        <Input.TextArea
          rows={3}
          placeholder="我想对你说..."
          value={whisperText}
          onChange={(e) => setWhisperText(e.target.value)}
          maxLength={200}
          showCount
          style={{ borderRadius: 12, marginBottom: 16 }}
        />
        <Button
          type="primary"
          block
          loading={sendingWhisper}
          onClick={handleSendWhisper}
          style={{ height: 46, borderRadius: 23 }}
        >
          💌 发送悄悄话
        </Button>
      </Modal>
    </div>
  );
}

/* ================================================================
   LOVE WORDS PAGE
   ================================================================ */
function LoveWordsPage() {
  const [notes, setNotes] = useState(STATIC_NOTES);
  const [activeCategory, setActiveCategory] = useState('all');
  const [currentIdx, setCurrentIdx] = useState<number | null>(null);
  const [showModal, setShowModal] = useState(false);

  useEffect(() => {
    (async () => {
      try {
        const res = await apiFetch('/love/notes');
        if (res.code === 200 && res.data?.length > 0) {
          setNotes(res.data.map((n: any) => ({ content: n.content, cat: n.category || 'love' })));
        }
      } catch { }
    })();
  }, []);

  const categories = [
    { key: 'all', label: '💝 全部', color: '#e91e63' },
    { key: 'love', label: '❤️ 爱的告白', color: '#f43f5e' },
    { key: 'romantic', label: '🌹 浪漫情话', color: '#a855f7' },
    { key: 'future', label: '🚀 未来承诺', color: '#3b82f6' },
    { key: 'promise', label: '🌟 永远守护', color: '#f59e0b' },
  ];

  const filtered = activeCategory === 'all' ? notes : notes.filter(n => n.cat === activeCategory);

  const emojis = ['💕', '💗', '💖', '🌸', '🌹', '✨', '🎀', '💛', '💞', '🎵'];

  return (
    <div className="page-enter">
      <div className="love-card" style={{ marginBottom: 24, textAlign: 'center', padding: '36px 24px' }}>
        <div style={{ fontSize: 48, marginBottom: 12, animation: 'bounce 2s ease-in-out infinite' }}>💗</div>
        <h2 className="love-title" style={{ fontSize: 'clamp(22px,4vw,36px)', marginBottom: 8 }}>甜蜜情话</h2>
        <p style={{ color: '#aaa', fontSize: 14 }}>每一句话，都是真心话 · 缐廷华 💕 阳婧欢</p>
      </div>

      <div style={{ display: 'flex', gap: 8, marginBottom: 20, flexWrap: 'wrap', justifyContent: 'center' }}>
        {categories.map(cat => (
          <button
            key={cat.key}
            onClick={() => setActiveCategory(cat.key)}
            style={{
              padding: '8px 20px', borderRadius: 50, border: 'none', cursor: 'pointer',
              fontSize: 13, fontWeight: 600, transition: 'all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)',
              background: activeCategory === cat.key
                ? `linear-gradient(135deg, ${cat.color}, ${cat.color}cc)`
                : 'rgba(255,255,255,0.8)',
              color: activeCategory === cat.key ? '#fff' : '#888',
              boxShadow: activeCategory === cat.key ? `0 4px 16px ${cat.color}55` : '0 2px 8px rgba(0,0,0,0.06)',
              transform: activeCategory === cat.key ? 'scale(1.05)' : 'scale(1)',
            }}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <Row gutter={[16, 16]}>
        {filtered.map((note, i) => (
          <Col xs={24} sm={12} lg={8} key={i}>
            <div
              className="note-card"
              style={{ animation: `fadeInUp ${0.1 + (i % 6) * 0.07}s ease`, cursor: 'pointer' }}
              onClick={() => { setCurrentIdx(i); setShowModal(true); }}
            >
              <div style={{ fontSize: 20, marginBottom: 10 }}>{emojis[i % emojis.length]}</div>
              <Typography.Text style={{ fontSize: 15, lineHeight: 1.8, color: '#444' }}>
                {note.content}
              </Typography.Text>
            </div>
          </Col>
        ))}
      </Row>

      <Modal
        open={showModal}
        footer={null}
        onCancel={() => setShowModal(false)}
        centered
        styles={{ body: { textAlign: 'center', padding: '40px 32px' } }}
      >
        {currentIdx !== null && (
          <>
            <div style={{ fontSize: 56, marginBottom: 16, animation: 'heartBeat 2s ease-in-out infinite' }}>💖</div>
            <Typography.Text style={{ fontSize: 20, lineHeight: 2, color: '#333', display: 'block', fontStyle: 'italic', fontWeight: 500 }}>
              "{filtered[currentIdx]?.content}"
            </Typography.Text>
            <div style={{ marginTop: 24, color: '#ff6b9d', fontSize: 13 }}>— 缐廷华 💕 阳婧欢，永远相爱</div>
            <div style={{ marginTop: 20, display: 'flex', gap: 12, justifyContent: 'center' }}>
              <button className="love-btn love-btn-ghost" style={{ fontSize: 13, padding: '8px 20px' }}
                onClick={() => setCurrentIdx(Math.max(0, (currentIdx || 0) - 1))}>← 上一句</button>
              <button className="love-btn love-btn-primary" style={{ fontSize: 13, padding: '8px 20px' }}
                onClick={() => setCurrentIdx(((currentIdx || 0) + 1) % filtered.length)}>下一句 →</button>
            </div>
          </>
        )}
      </Modal>
    </div>
  );
}

/* ================================================================
   PHOTOS PAGE
   ================================================================ */
function PhotosPage() {
  const [photos, setPhotos] = useState<any[]>([]);
  const [uploading, setUploading] = useState(false);
  const [previewVisible, setPreviewVisible] = useState(false);
  const [previewIdx, setPreviewIdx] = useState(0);

  const loadPhotos = async () => {
    try {
      const res = await apiFetch('/photos');
      if (res.code === 200) setPhotos(res.data || []);
    } catch { }
  };

  useEffect(() => { loadPhotos(); }, []);

  const handleUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const files = e.target.files;
    if (!files || files.length === 0) return;
    setUploading(true);
    const formData = new FormData();
    for (let i = 0; i < files.length; i++) {
      formData.append('photos', files[i]);
    }
    try {
      const res = await apiFetch('/photos/upload', { method: 'POST', body: formData });
      if (res.code === 201) {
        message.success(`🎉 成功上传 ${res.data?.length || 0} 张照片！`);
        loadPhotos();
      } else {
        message.error(res.message || '上传失败');
      }
    } catch {
      message.error('上传失败，请重试');
    }
    setUploading(false);
    e.target.value = '';
  };

  const handleDelete = async (id: number, e: React.MouseEvent) => {
    e.stopPropagation();
    try {
      const res = await apiFetch(`/photos/${id}`, { method: 'DELETE' });
      if (res.code === 200) {
        message.success('💨 已删除');
        loadPhotos();
      }
    } catch {
      message.error('删除失败');
    }
  };

  const prevPhoto = () => setPreviewIdx(i => Math.max(0, i - 1));
  const nextPhoto = () => setPreviewIdx(i => Math.min(photos.length - 1, i + 1));

  return (
    <div className="page-enter">
      <div className="love-card" style={{ marginBottom: 24, display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: 12 }}>
        <div>
          <h2 style={{ fontSize: 22, fontWeight: 800, background: 'var(--gradient-love)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent', backgroundClip: 'text', marginBottom: 4 }}>
            📸 我们的回忆
          </h2>
          <p style={{ color: '#aaa', fontSize: 14, margin: 0 }}>
            {photos.length > 0 ? `已收藏 ${photos.length} 张珍贵瞬间` : '记录属于我们的每一个瞬间'}
          </p>
        </div>
        <label style={{
          display: 'inline-flex', alignItems: 'center', gap: 8, padding: '10px 22px',
          borderRadius: 50, cursor: 'pointer',
          background: 'var(--gradient-love)', color: '#fff', fontWeight: 600, fontSize: 14,
          boxShadow: '0 4px 20px rgba(255,45,120,0.35)',
          transition: 'all 0.3s', opacity: uploading ? 0.7 : 1,
        }}>
          <UploadOutlined />
          {uploading ? '上传中...' : '+ 上传照片'}
          <input type="file" accept="image/*" multiple onChange={handleUpload} style={{ display: 'none' }} disabled={uploading} />
        </label>
      </div>

      {photos.length === 0 ? (
        <div className="love-card" style={{ textAlign: 'center', padding: '80px 20px' }}>
          <div style={{ fontSize: 72, marginBottom: 16 }}>📷</div>
          <h3 style={{ color: '#e91e63', marginBottom: 8 }}>还没有照片</h3>
          <p style={{ color: '#bbb', marginBottom: 28 }}>上传你们的第一张合照，让回忆永远留在这里</p>
          <label style={{ display: 'inline-flex', alignItems: 'center', gap: 8, padding: '14px 36px', borderRadius: 50, cursor: 'pointer', background: 'var(--gradient-love)', color: '#fff', fontWeight: 700, fontSize: 16, boxShadow: '0 6px 24px rgba(255,45,120,0.4)' }}>
            <PlusOutlined /> 立即上传
            <input type="file" accept="image/*" multiple onChange={handleUpload} style={{ display: 'none' }} />
          </label>
        </div>
      ) : (
        <Row gutter={[12, 12]}>
          {photos.map((photo: any, idx: number) => (
            <Col xs={12} sm={8} md={6} key={photo.id}>
              <div
                className="photo-item"
                onClick={() => { setPreviewIdx(idx); setPreviewVisible(true); }}
                style={{ animation: `scaleIn ${0.1 + (idx % 8) * 0.06}s ease` }}
              >
                <img
                  src={`/api/photos/file/${photo.filename}`}
                  alt={photo.title || 'memory'}
                  style={{ width: '100%', aspectRatio: '1', objectFit: 'cover', display: 'block' }}
                  loading="lazy"
                />
                <div className="photo-overlay">
                  {photo.title && <div style={{ color: '#fff', fontSize: 12, fontWeight: 600, marginBottom: 2 }}>{photo.title}</div>}
                  <div style={{ color: 'rgba(255,255,255,0.7)', fontSize: 11 }}>{dayjs(photo.created_at).format('YYYY-MM-DD')}</div>
                </div>
                <div
                  style={{ position: 'absolute', top: 8, right: 8, zIndex: 2 }}
                  onClick={(e) => handleDelete(photo.id, e)}
                >
                  <div style={{ width: 30, height: 30, borderRadius: '50%', background: 'rgba(0,0,0,0.55)', display: 'flex', alignItems: 'center', justifyContent: 'center', cursor: 'pointer', backdropFilter: 'blur(4px)' }}>
                    <DeleteOutlined style={{ color: '#fff', fontSize: 13 }} />
                  </div>
                </div>
              </div>
            </Col>
          ))}
        </Row>
      )}

      <Modal
        open={previewVisible}
        footer={null}
        onCancel={() => setPreviewVisible(false)}
        centered
        width="auto"
        styles={{ body: { padding: 0, background: 'rgba(0,0,0,0.95)', borderRadius: 20, overflow: 'hidden', textAlign: 'center' } }}
        style={{ maxWidth: '96vw' }}
      >
        <div style={{ position: 'relative', display: 'inline-block' }}>
          <img
            src={photos[previewIdx] ? `/api/photos/file/${photos[previewIdx].filename}` : ''}
            alt="preview"
            style={{ maxWidth: '90vw', maxHeight: '82vh', display: 'block', borderRadius: 12 }}
          />
          <div style={{ position: 'absolute', bottom: 16, left: '50%', transform: 'translateX(-50%)', display: 'flex', gap: 12, alignItems: 'center' }}>
            <button onClick={prevPhoto} disabled={previewIdx === 0} style={{ width: 36, height: 36, borderRadius: '50%', border: 'none', background: 'rgba(255,255,255,0.15)', color: '#fff', cursor: previewIdx === 0 ? 'not-allowed' : 'pointer', fontSize: 16, backdropFilter: 'blur(8px)' }}>‹</button>
            <span style={{ color: 'rgba(255,255,255,0.6)', fontSize: 13 }}>{previewIdx + 1} / {photos.length}</span>
            <button onClick={nextPhoto} disabled={previewIdx === photos.length - 1} style={{ width: 36, height: 36, borderRadius: '50%', border: 'none', background: 'rgba(255,255,255,0.15)', color: '#fff', cursor: previewIdx === photos.length - 1 ? 'not-allowed' : 'pointer', fontSize: 16, backdropFilter: 'blur(8px)' }}>›</button>
          </div>
        </div>
        {photos[previewIdx]?.title && (
          <div style={{ padding: '12px 20px', color: 'rgba(255,255,255,0.8)', fontSize: 14 }}>{photos[previewIdx].title}</div>
        )}
      </Modal>
    </div>
  );
}

/* ================================================================
   VIDEOS PAGE — 爱的影集
   ================================================================ */
function VideosPage() {
  const [videos, setVideos] = useState<any[]>([]);
  const [uploading, setUploading] = useState(false);
  const [playingVideo, setPlayingVideo] = useState<any>(null);
  const [uploadProgress, setUploadProgress] = useState(0);
  const videoModalRef = useRef<HTMLVideoElement>(null);
  const thumbRefs = useRef<Record<string, HTMLVideoElement>>({});

  const loadVideos = async () => {
    try {
      const res = await apiFetch('/videos');
      if (res.code === 200) setVideos(res.data || []);
    } catch { }
  };

  useEffect(() => {
    loadVideos();
    // 为每个视频生成缩略图：seek 到 1 秒处
    setTimeout(() => {
      Object.values(thumbRefs.current).forEach(v => {
        if (v && v.readyState >= 1) {
          v.currentTime = 1;
        }
      });
    }, 1000);
  }, []);

  const handleVideoLoaded = (id: string) => {
    const v = thumbRefs.current[id];
    if (v) v.currentTime = 1;
  };

  const handleUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    setUploading(true);
    setUploadProgress(0);

    const formData = new FormData();
    formData.append('video', file);

    try {
      // 使用 XMLHttpRequest 以支持进度回调
      await new Promise<void>((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        const token = localStorage.getItem('token');
        xhr.upload.addEventListener('progress', (ev) => {
          if (ev.lengthComputable) {
            setUploadProgress(Math.round(ev.loaded / ev.total * 100));
          }
        });
        xhr.addEventListener('load', () => {
          try {
            const data = JSON.parse(xhr.responseText);
            if (data.code === 201) {
              message.success('🎬 视频上传成功！');
              loadVideos();
              resolve();
            } else {
              message.error(data.message || '上传失败');
              reject();
            }
          } catch { reject(); }
        });
        xhr.addEventListener('error', () => { message.error('上传失败'); reject(); });
        xhr.open('POST', '/api/videos/upload');
        if (token) xhr.setRequestHeader('Authorization', `Bearer ${token}`);
        xhr.send(formData);
      });
    } catch { }

    setUploading(false);
    setUploadProgress(0);
    e.target.value = '';
  };

  const handleDelete = async (id: number) => {
    try {
      const res = await apiFetch(`/videos/${id}`, { method: 'DELETE' });
      if (res.code === 200) {
        message.success('已删除');
        loadVideos();
      }
    } catch { message.error('删除失败'); }
  };

  const formatSize = (bytes: number) => {
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
  };

  return (
    <div className="page-enter">
      {/* 头部 */}
      <div className="love-card" style={{ marginBottom: 24, display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: 12 }}>
        <div>
          <h2 style={{ fontSize: 22, fontWeight: 800, background: 'var(--gradient-love)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent', backgroundClip: 'text', marginBottom: 4 }}>
            🎬 爱的影集
          </h2>
          <p style={{ color: '#aaa', fontSize: 14, margin: 0 }}>
            {videos.length > 0 ? `珍藏了 ${videos.length} 段珍贵视频` : '记录属于我们的珍贵视频'}
          </p>
        </div>
        <label style={{
          display: 'inline-flex', alignItems: 'center', gap: 8, padding: '10px 22px',
          borderRadius: 50, cursor: 'pointer',
          background: 'var(--gradient-love)', color: '#fff', fontWeight: 600, fontSize: 14,
          boxShadow: '0 4px 20px rgba(255,45,120,0.35)',
          opacity: uploading ? 0.7 : 1,
          pointerEvents: uploading ? 'none' : 'auto',
        }}>
          <VideoCameraOutlined />
          {uploading ? `上传中 ${uploadProgress}%...` : '+ 上传视频'}
          <input type="file" accept="video/*" onChange={handleUpload} style={{ display: 'none' }} disabled={uploading} />
        </label>
      </div>

      {/* 上传进度条 */}
      {uploading && (
        <div style={{ marginBottom: 16 }}>
          <div style={{ background: 'rgba(255,255,255,0.8)', borderRadius: 20, padding: '12px 20px', boxShadow: '0 4px 20px rgba(255,45,120,0.12)' }}>
            <div style={{ fontSize: 13, color: '#e91e63', marginBottom: 8, fontWeight: 600 }}>
              🎬 正在上传视频... {uploadProgress}%
            </div>
            <div style={{ height: 8, background: 'rgba(255,107,157,0.15)', borderRadius: 4, overflow: 'hidden' }}>
              <div style={{
                height: '100%', borderRadius: 4,
                background: 'var(--gradient-love)',
                width: `${uploadProgress}%`,
                transition: 'width 0.2s',
              }} />
            </div>
          </div>
        </div>
      )}

      {/* 视频列表 */}
      {videos.length === 0 ? (
        <div className="love-card" style={{ textAlign: 'center', padding: '80px 20px' }}>
          <div style={{ fontSize: 72, marginBottom: 16 }}>🎥</div>
          <h3 style={{ color: '#e91e63', marginBottom: 8 }}>还没有视频</h3>
          <p style={{ color: '#bbb', marginBottom: 28 }}>上传你们的第一段视频，让美好永远留存</p>
          <label style={{ display: 'inline-flex', alignItems: 'center', gap: 8, padding: '14px 36px', borderRadius: 50, cursor: 'pointer', background: 'var(--gradient-love)', color: '#fff', fontWeight: 700, fontSize: 16, boxShadow: '0 6px 24px rgba(255,45,120,0.4)' }}>
            <PlusOutlined /> 立即上传
            <input type="file" accept="video/*" onChange={handleUpload} style={{ display: 'none' }} />
          </label>
        </div>
      ) : (
        <Row gutter={[16, 16]}>
          {videos.map((video: any, idx: number) => (
            <Col xs={24} sm={12} lg={8} key={video.id}>
              <div
                className="video-card"
                style={{ animation: `scaleIn ${0.1 + (idx % 6) * 0.07}s ease` }}
              >
                {/* 视频缩略图区域 */}
                <div
                  className="video-thumb"
                  onClick={() => setPlayingVideo(video)}
                >
                  <video
                    ref={(el) => { if (el && video.id) thumbRefs.current[String(video.id)] = el; }}
                    src={`/api/videos/file/${video.filename}`}
                    style={{ width: '100%', height: '100%', objectFit: 'cover' }}
                    preload="metadata"
                    muted
                    playsInline
                    onLoadedData={() => handleVideoLoaded(String(video.id))}
                  />
                  <div className="video-play-overlay">
                    <div className="video-play-btn">
                      <PlayCircleOutlined style={{ fontSize: 44, color: '#fff' }} />
                    </div>
                  </div>
                </div>
                {/* 视频信息 */}
                <div style={{ padding: '12px 14px' }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: 8 }}>
                    <div style={{ flex: 1, minWidth: 0 }}>
                      <div style={{ fontSize: 14, fontWeight: 600, color: '#333', marginBottom: 4, whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                        {video.title || `💕 我们的视频 ${idx + 1}`}
                      </div>
                      <div style={{ fontSize: 12, color: '#bbb' }}>
                        {dayjs(video.created_at).format('YYYY-MM-DD')} · {formatSize(video.size)}
                      </div>
                    </div>
                    <Popconfirm title="确定删除这段视频？" onConfirm={() => handleDelete(video.id)} okText="删除" cancelText="取消">
                      <button style={{ width: 28, height: 28, borderRadius: '50%', border: '1px solid rgba(255,107,157,0.25)', background: 'transparent', cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#ff6b9d', fontSize: 12, flexShrink: 0 }}>🗑</button>
                    </Popconfirm>
                  </div>
                </div>
              </div>
            </Col>
          ))}
        </Row>
      )}

      {/* 视频播放弹窗 */}
      <Modal
        open={!!playingVideo}
        footer={null}
        onCancel={() => { setPlayingVideo(null); videoModalRef.current?.pause(); }}
        centered
        width="auto"
        destroyOnClose
        styles={{ body: { padding: 0, background: '#000', borderRadius: 20, overflow: 'hidden', textAlign: 'center' } }}
        style={{ maxWidth: '96vw' }}
      >
        {playingVideo && (
          <div>
            <video
              ref={videoModalRef}
              src={`/api/videos/file/${playingVideo.filename}`}
              controls
              autoPlay
              style={{ maxWidth: '90vw', maxHeight: '80vh', display: 'block', borderRadius: '0 0 16px 16px' }}
            />
            <div style={{ padding: '14px 20px', background: 'rgba(0,0,0,0.9)', color: 'rgba(255,255,255,0.85)', fontSize: 14, fontWeight: 500 }}>
              {playingVideo.title || '💕 我们的美好时光'}
              <span style={{ marginLeft: 12, color: 'rgba(255,255,255,0.4)', fontSize: 12 }}>
                {dayjs(playingVideo.created_at).format('YYYY年MM月DD日')}
              </span>
            </div>
          </div>
        )}
      </Modal>
    </div>
  );
}

/* ================================================================
   ANNIVERSARY PAGE
   ================================================================ */
function AnniversaryPage() {
  const [items, setItems] = useState<any[]>([]);
  const [loading, setLoading] = useState(false);
  const [modalOpen, setModalOpen] = useState(false);
  const [form] = Form.useForm();
  const [editingId, setEditingId] = useState<number | null>(null);

  const loadItems = async () => {
    setLoading(true);
    try {
      const res = await apiFetch('/love/anniversaries');
      if (res.code === 200) setItems(res.data || []);
    } catch { }
    setLoading(false);
  };

  useEffect(() => { loadItems(); }, []);

  const handleSubmit = async (values: any) => {
    try {
      const body = { title: values.title, date: values.date.format('YYYY-MM-DD') };
      if (editingId) {
        await apiFetch(`/love/anniversaries/${editingId}`, { method: 'PUT', body: JSON.stringify(body) });
        message.success('✅ 更新成功');
      } else {
        await apiFetch('/love/anniversaries', { method: 'POST', body: JSON.stringify(body) });
        message.success('🎉 添加成功！');
      }
      setModalOpen(false);
      form.resetFields();
      setEditingId(null);
      loadItems();
    } catch { message.error('操作失败'); }
  };

  const handleDelete = async (id: number) => {
    try {
      await apiFetch(`/love/anniversaries/${id}`, { method: 'DELETE' });
      message.success('已删除');
      loadItems();
    } catch { message.error('删除失败'); }
  };

  const emojiList = ['💝', '🎂', '💒', '🌹', '🎁', '✈️', '🎓', '💍', '🏠', '🌟'];

  return (
    <div className="page-enter">
      <div className="love-card" style={{ marginBottom: 24, display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: 12 }}>
        <div>
          <h2 style={{ fontSize: 22, fontWeight: 800, background: 'var(--gradient-love)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent', backgroundClip: 'text', marginBottom: 4 }}>
            📅 我们的纪念日
          </h2>
          <p style={{ color: '#aaa', fontSize: 14, margin: 0 }}>记录每一个重要的日子，让爱有迹可循</p>
        </div>
        <button
          className="love-btn love-btn-primary"
          onClick={() => { setEditingId(null); form.resetFields(); setModalOpen(true); }}
          style={{ fontSize: 14 }}
        >
          <GiftOutlined /> 添加纪念日
        </button>
      </div>

      {items.length === 0 ? (
        <div className="love-card" style={{ textAlign: 'center', padding: '60px 20px' }}>
          <div style={{ fontSize: 64, marginBottom: 16 }}>🗓️</div>
          <h3 style={{ color: '#e91e63', marginBottom: 8 }}>还没有纪念日</h3>
          <p style={{ color: '#bbb', marginBottom: 24 }}>快去添加你们的第一个重要日子吧！</p>
          <button className="love-btn love-btn-primary" onClick={() => { form.resetFields(); setModalOpen(true); }}>
            ✨ 添加第一个纪念日
          </button>
        </div>
      ) : (
        <Row gutter={[16, 16]}>
          {items.map((item: any, idx: number) => {
            const days = item.days_together || 0;
            const daysUntil = item.days_until_next || 0;
            const emoji = emojiList[idx % emojiList.length];
            const isUpcoming = daysUntil <= 30;
            return (
              <Col xs={24} sm={12} lg={8} key={item.id}>
                <div
                  className="anniversary-card"
                  style={{
                    animation: `scaleIn ${0.1 + idx * 0.08}s ease`,
                    border: isUpcoming ? '2px solid #ff6b9d' : undefined,
                  }}
                >
                  {isUpcoming && (
                    <div style={{ position: 'absolute', top: -1, right: 20, background: 'var(--gradient-love)', color: '#fff', fontSize: 11, fontWeight: 700, padding: '3px 10px', borderRadius: '0 0 10px 10px' }}>
                      🔔 即将到来
                    </div>
                  )}
                  <div style={{ position: 'absolute', top: 12, right: 12, display: 'flex', gap: 4 }}>
                    <button
                      onClick={() => { setEditingId(item.id); form.setFieldsValue({ title: item.title, date: dayjs(item.date) }); setModalOpen(true); }}
                      style={{ width: 28, height: 28, borderRadius: '50%', border: '1px solid rgba(255,107,157,0.3)', background: 'transparent', cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#ff6b9d', fontSize: 12 }}
                    >✏️</button>
                    <Popconfirm title="确定删除这个纪念日？" onConfirm={() => handleDelete(item.id)} okText="删除" cancelText="取消">
                      <button style={{ width: 28, height: 28, borderRadius: '50%', border: '1px solid rgba(255,107,157,0.2)', background: 'transparent', cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#ff6b9d', fontSize: 12 }}>🗑</button>
                    </Popconfirm>
                  </div>
                  <div style={{ fontSize: 40, marginBottom: 10 }}>{emoji}</div>
                  <h4 style={{ fontSize: 16, fontWeight: 700, color: '#333', marginBottom: 6 }}>{item.title}</h4>
                  <p style={{ color: '#ff6b9d', fontSize: 13, fontWeight: 600, marginBottom: 12 }}>
                    {dayjs(item.date).format('YYYY年MM月DD日')}
                  </p>
                  <div style={{ display: 'flex', gap: 6, justifyContent: 'center', flexWrap: 'wrap' }}>
                    <span className="love-badge">⏱ 已过 {days} 天</span>
                    {daysUntil > 0 && <span className="love-badge">🎯 还有 {daysUntil} 天</span>}
                    {daysUntil === 0 && <span className="love-badge" style={{ background: 'linear-gradient(135deg,#ff6b9d,#ff2d78)', color: '#fff' }}>🎉 今天！</span>}
                  </div>
                </div>
              </Col>
            );
          })}
        </Row>
      )}

      <Modal
        title={<span style={{ color: '#e91e63', fontWeight: 700 }}>{editingId ? '✏️ 编辑纪念日' : '🎁 添加纪念日'}</span>}
        open={modalOpen}
        onCancel={() => setModalOpen(false)}
        footer={null}
        styles={{ body: { paddingTop: 20 } }}
      >
        <Form form={form} layout="vertical" onFinish={handleSubmit}>
          <Form.Item name="title" label="纪念日名称" rules={[{ required: true, message: '请输入名称' }]}>
            <Input placeholder="例如：我们在一起的第一天 💕" />
          </Form.Item>
          <Form.Item name="date" label="日期" rules={[{ required: true, message: '请选择日期' }]}>
            <DatePicker style={{ width: '100%' }} placeholder="选择日期" />
          </Form.Item>
          <Form.Item style={{ marginBottom: 0 }}>
            <Button type="primary" htmlType="submit" block style={{ height: 46, fontSize: 15 }}>
              {editingId ? '保存修改 ✅' : '添加纪念日 🎉'}
            </Button>
          </Form.Item>
        </Form>
      </Modal>
    </div>
  );
}

/* ================================================================
   PROFILE PAGE - 双人头像版 v3.0
   ================================================================ */
function ProfilePage({ user, setUser }: { user: any; setUser: (u: any) => void }) {
  const [loading, setLoading] = useState(false);
  const [editing, setEditing] = useState(false);
  const [uploadingAvatar, setUploadingAvatar] = useState(false);
  const [uploadingPartner, setUploadingPartner] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);
  const [form] = Form.useForm();
  const navigate = useNavigate();

  useEffect(() => {
    if (user) form.setFieldsValue({
      nickname: user.nickname || '',
      email: user.email || '',
      signature: user.signature || '',
      partner_name: user.partner_name || ''
    });
  }, [user, form]);

  const handleSave = async (values: any) => {
    setLoading(true);
    try {
      const res = await apiFetch('/auth/profile', { method: 'PUT', body: JSON.stringify(values) });
      if (res.code === 200) {
        setUser(res.data);
        localStorage.setItem('user', JSON.stringify(res.data));
        message.success('💖 保存成功！');
        setEditing(false);
      } else {
        message.error(res.message);
      }
    } catch { message.error('保存失败'); }
    setLoading(false);
  };

  const handleAvatarUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) {
      message.error('图片不能超过 5MB');
      return;
    }
    setUploadingAvatar(true);
    setUploadProgress(0);

    const formData = new FormData();
    formData.append('avatar', file);

    // 使用 XMLHttpRequest 以支持进度
    await new Promise<void>((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      const token = localStorage.getItem('token');
      xhr.upload.addEventListener('progress', (ev) => {
        if (ev.lengthComputable) {
          setUploadProgress(Math.round(ev.loaded / ev.total * 100));
        }
      });
      xhr.addEventListener('load', () => {
        try {
          const data = JSON.parse(xhr.responseText);
          if (data.code === 200) {
            setUser(data.data);
            localStorage.setItem('user', JSON.stringify(data.data));
            message.success('💖 头像更新成功！');
            resolve();
          } else {
            message.error(data.message || '上传失败');
            reject();
          }
        } catch { reject(); }
      });
      xhr.addEventListener('error', () => { message.error('上传失败'); reject(); });
      xhr.open('POST', '/api/auth/avatar');
      if (token) xhr.setRequestHeader('Authorization', `Bearer ${token}`);
      xhr.send(formData);
    });

    setUploadingAvatar(false);
    setUploadProgress(0);
    e.target.value = '';
  };

  const handlePartnerAvatarUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) {
      message.error('图片不能超过 5MB');
      return;
    }
    setUploadingPartner(true);
    setUploadProgress(0);

    const formData = new FormData();
    formData.append('avatar', file);

    await new Promise<void>((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      const token = localStorage.getItem('token');
      xhr.upload.addEventListener('progress', (ev) => {
        if (ev.lengthComputable) {
          setUploadProgress(Math.round(ev.loaded / ev.total * 100));
        }
      });
      xhr.addEventListener('load', () => {
        try {
          const data = JSON.parse(xhr.responseText);
          if (data.code === 200) {
            setUser(data.data);
            localStorage.setItem('user', JSON.stringify(data.data));
            message.success('💖 TA的头像更新成功！');
            resolve();
          } else {
            message.error(data.message || '上传失败');
            reject();
          }
        } catch { reject(); }
      });
      xhr.addEventListener('error', () => { message.error('上传失败'); reject(); });
      xhr.open('POST', '/api/auth/partner-avatar');
      if (token) xhr.setRequestHeader('Authorization', `Bearer ${token}`);
      xhr.send(formData);
    });

    setUploadingPartner(false);
    setUploadProgress(0);
    e.target.value = '';
  };

  if (!user) return <div style={{ textAlign: 'center', padding: 40 }}>加载中...</div>;

  const avatarUrl = user.avatar ? (user.avatar.startsWith('/') ? user.avatar : `/api/auth/avatar/${user.avatar}`) : null;
  const partnerAvatarUrl = user.partner_avatar ? (user.partner_avatar.startsWith('/') ? user.partner_avatar : `/api/auth/avatar/${user.partner_avatar}`) : null;
  const avatarEmoji = ['😊', '🥰', '😍', '💕', '🌸'][user.id % 5] || '😊';
  const partnerEmoji = ['😎', '🤗', '😘', '🥰', '😚'][user.id % 5] || '🥰';
  const daysTogether = dayjs().diff(dayjs('2026-01-14'), 'day');

  // 自定义样式
  const customStyles = `
    @keyframes breathe {
      0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,157,0.4), 0 8px 32px rgba(255,45,120,0.3); }
      50% { box-shadow: 0 0 0 12px rgba(255,107,157,0), 0 8px 32px rgba(255,45,120,0.4); }
    }
    .avatar-breathe {
      animation: breathe 3s ease-in-out infinite;
    }
    .avatar-upload-overlay {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: rgba(255,45,120,0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s;
      cursor: pointer;
    }
    .avatar-container:hover .avatar-upload-overlay {
      opacity: 1;
    }
    .progress-ring {
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      background: conic-gradient(var(--gradient-love) var(--progress), rgba(255,255,255,0.2) 0);
      z-index: -1;
    }
    .profile-card-group {
      margin-bottom: 16px;
      padding: 16px;
      background: rgba(255,255,255,0.6);
      border-radius: 16px;
      border: 1px solid rgba(255,107,157,0.15);
    }
    .profile-card-title {
      font-size: 13px;
      font-weight: 600;
      color: #e91e63;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .love-particle {
      position: absolute;
      width: 4px;
      height: 4px;
      background: #ff6b9d;
      border-radius: 50%;
      opacity: 0.6;
      animation: float 4s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); opacity: 0.6; }
      50% { transform: translateY(-10px); opacity: 0.3; }
    }
  `;

  // 圆形进度环组件
  const CircularProgress = ({ progress, children }: { progress: number; children: React.ReactNode }) => (
    <div style={{ position: 'relative' }}>
      <div className="progress-ring" style={{ background: `conic-gradient(#ff6b9d ${progress}%, rgba(255,255,255,0.2) 0)` }} />
      {children}
    </div>
  );

  return (
    <div className="page-enter" style={{ maxWidth: 640, margin: '0 auto' }}>
      <style>{customStyles}</style>

      {/* 双人头大卡片 */}
      <div className="love-card" style={{ textAlign: 'center', marginBottom: 20, padding: '40px 24px 32px', position: 'relative', overflow: 'hidden' }}>
        {/* 漂浮爱心粒子 */}
        {[...Array(6)].map((_, i) => (
          <div key={i} className="love-particle" style={{
            left: `${15 + i * 12}%`,
            top: `${20 + (i % 3) * 20}%`,
            animationDelay: `${i * 0.5}s`
          }} />
        ))}

        {/* 双人头像区域 */}
        <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', gap: 8, marginBottom: 24, position: 'relative' }}>

          {/* 我的头像 */}
          <div className="avatar-container" style={{ position: 'relative' }}>
            <CircularProgress progress={uploadingAvatar ? uploadProgress : 0}>
              <label style={{ cursor: uploadingAvatar ? 'wait' : 'pointer', display: 'block' }}>
                <div
                  className="avatar-breathe"
                  style={{
                    width: 120, height: 120, borderRadius: '50%',
                    display: 'flex', alignItems: 'center', justifyContent: 'center',
                    border: '5px solid #fff',
                    position: 'relative',
                    overflow: 'hidden',
                  }}
                >
                  {avatarUrl ? (
                    <img src={avatarUrl} alt="我的头像" style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                  ) : (
                    <div style={{
                      width: '100%', height: '100%',
                      background: 'var(--gradient-love)',
                      display: 'flex', alignItems: 'center', justifyContent: 'center',
                      fontSize: 56,
                    }}>
                      {avatarEmoji}
                    </div>
                  )}
                </div>

                {/* 悬浮上传层 */}
                <div className="avatar-upload-overlay">
                  {uploadingAvatar ? (
                    <div style={{ textAlign: 'center' }}>
                      <div style={{ fontSize: 24 }}>⏳</div>
                      <div style={{ fontSize: 12 }}>{uploadProgress}%</div>
                    </div>
                  ) : (
                    <>
                      <CameraOutlined style={{ fontSize: 28, color: '#fff' }} />
                    </>
                  )}
                </div>

                <input type="file" accept="image/*" onChange={handleAvatarUpload} style={{ display: 'none' }} disabled={uploadingAvatar} />
              </label>
            </CircularProgress>
            <div style={{ marginTop: 10, fontSize: 14, fontWeight: 700, color: '#e91e63' }}>{user.nickname || user.username}</div>
            <div style={{ fontSize: 11, color: '#bbb' }}>👤 我</div>
          </div>

          {/* 爱心连接 */}
          <div style={{
            margin: '0 -4px', zIndex: 1,
            width: 50, height: 50, borderRadius: '50%',
            background: 'var(--gradient-love)',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            fontSize: 24, boxShadow: '0 4px 20px rgba(255,45,120,0.4)',
            border: '4px solid #fff',
          }}>
            💕
          </div>

          {/* TA的头像 */}
          <div className="avatar-container" style={{ position: 'relative' }}>
            <CircularProgress progress={uploadingPartner ? uploadProgress : 0}>
              <label style={{ cursor: uploadingPartner ? 'wait' : 'pointer', display: 'block' }}>
                <div
                  className="avatar-breathe"
                  style={{
                    width: 120, height: 120, borderRadius: '50%',
                    display: 'flex', alignItems: 'center', justifyContent: 'center',
                    border: '5px solid #fff',
                    position: 'relative',
                    overflow: 'hidden',
                    animationDelay: '1.5s',
                  }}
                >
                  {partnerAvatarUrl ? (
                    <img src={partnerAvatarUrl} alt="TA的头像" style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                  ) : (
                    <div style={{
                      width: '100%', height: '100%',
                      background: 'linear-gradient(135deg, #a855f7, #ec4899)',
                      display: 'flex', alignItems: 'center', justifyContent: 'center',
                      fontSize: 56,
                    }}>
                      {user.partner_name ? user.partner_name[0] : partnerEmoji}
                    </div>
                  )}
                </div>

                {/* 悬浮上传层 */}
                <div className="avatar-upload-overlay" style={{ background: 'rgba(168,85,247,0.7)' }}>
                  {uploadingPartner ? (
                    <div style={{ textAlign: 'center' }}>
                      <div style={{ fontSize: 24 }}>⏳</div>
                      <div style={{ fontSize: 12 }}>{uploadProgress}%</div>
                    </div>
                  ) : (
                    <>
                      <CameraOutlined style={{ fontSize: 28, color: '#fff' }} />
                    </>
                  )}
                </div>

                <input type="file" accept="image/*" onChange={handlePartnerAvatarUpload} style={{ display: 'none' }} disabled={uploadingPartner} />
              </label>
            </CircularProgress>
            <div style={{ marginTop: 10, fontSize: 14, fontWeight: 700, color: '#a855f7' }}>{user.partner_name || 'TA'}</div>
            <div style={{ fontSize: 11, color: '#bbb' }}>💜 爱人</div>
          </div>
        </div>

        {/* 签名 */}
        {user.signature && (
          <div style={{ marginTop: 16, padding: '10px 20px', background: 'linear-gradient(135deg, rgba(255,240,246,0.8), rgba(255,220,235,0.5))', borderRadius: 12, color: '#666', fontSize: 14, fontStyle: 'italic' }}>
            💬 "{user.signature}"
          </div>
        )}
        <p style={{ color: '#aaa', fontSize: 12, marginTop: 12 }}>💕 点击头像更换 · @{user.username}</p>
      </div>

      {/* 个人资料卡片 - 分组 */}
      <div className="love-card" style={{ marginBottom: 20 }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
          <h3 style={{ margin: 0, fontSize: 16, fontWeight: 700, color: '#333' }}>👤 个人资料</h3>
          <button
            className={editing ? 'love-btn love-btn-ghost' : 'love-btn love-btn-primary'}
            style={{ fontSize: 13, padding: '8px 20px' }}
            onClick={() => {
              if (editing) { form.resetFields(); form.setFieldsValue({ nickname: user.nickname || '', email: user.email || '', signature: user.signature || '', partner_name: user.partner_name || '' }); }
              setEditing(!editing);
            }}
          >
            {editing ? '取消' : '✏️ 编辑'}
          </button>
        </div>

        {editing ? (
          <Form form={form} layout="vertical" onFinish={handleSave}>
            {/* 基本信息 */}
            <div className="profile-card-group">
              <div className="profile-card-title">📝 基本信息</div>
              <Form.Item name="nickname" label="我的昵称">
                <Input prefix={<span style={{ color: '#e91e63' }}>👤</span>} placeholder="你的昵称" />
              </Form.Item>
              <Form.Item name="email" label="邮箱">
                <Input prefix={<MailOutlined style={{ color: '#e91e63' }} />} placeholder="你的邮箱" />
              </Form.Item>
            </div>

            {/* TA的信息 */}
            <div className="profile-card-group">
              <div className="profile-card-title">💜 TA的信息</div>
              <Form.Item name="partner_name" label="TA的名字">
                <Input prefix={<span style={{ color: '#a855f7' }}>💕</span>} placeholder="你爱的人的名字" />
              </Form.Item>
            </div>

            {/* 个性签名 */}
            <div className="profile-card-group">
              <div className="profile-card-title">✨ 个性签名</div>
              <Form.Item name="signature" label="想对TA说">
                <Input.TextArea rows={2} placeholder="写一句甜甜的话..." maxLength={200} showCount />
              </Form.Item>
            </div>

            <Form.Item style={{ marginBottom: 0 }}>
              <Button type="primary" htmlType="submit" block loading={loading} style={{ height: 46, fontSize: 15 }}>
                💾 保存修改
              </Button>
            </Form.Item>
          </Form>
        ) : (
          <div>
            {/* 基本信息 */}
            <div className="profile-card-group">
              <div className="profile-card-title">📝 基本信息</div>
              {[
                { icon: '👤', label: '我的昵称', value: user.nickname || '未设置', color: '#e91e63' },
                { icon: '📧', label: '邮箱', value: user.email || '未设置', color: '#666' },
              ].map((f, i) => (
                <div key={i} style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '12px 0', borderBottom: i < 1 ? '1px solid rgba(255,107,157,0.1)' : 'none' }}>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                    <span style={{ fontSize: 18 }}>{f.icon}</span>
                    <span style={{ color: '#888', fontSize: 13 }}>{f.label}</span>
                  </div>
                  <span style={{ color: f.color, fontWeight: 500 }}>{f.value}</span>
                </div>
              ))}
            </div>

            {/* TA的信息 */}
            <div className="profile-card-group">
              <div className="profile-card-title">💜 TA的信息</div>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '12px 0' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <span style={{ fontSize: 18 }}>💕</span>
                  <span style={{ color: '#888', fontSize: 13 }}>TA的名字</span>
                </div>
                <span style={{ color: '#a855f7', fontWeight: 500 }}>{user.partner_name || '未设置'}</span>
              </div>
            </div>

            {/* 个性签名 */}
            {user.signature && (
              <div className="profile-card-group">
                <div className="profile-card-title">✨ 个性签名</div>
                <div style={{ color: '#666', fontStyle: 'italic', padding: '8px 0' }}>
                  "{user.signature}"
                </div>
              </div>
            )}
          </div>
        )}
      </div>

      {/* 爱情数据区域 - 增强版 */}
      <div className="love-card" style={{ marginBottom: 20 }}>
        <h3 style={{ margin: '0 0 16px', fontSize: 16, fontWeight: 700, color: '#333' }}>💕 爱情数据</h3>
        <Row gutter={[12, 12]}>
          {[
            { emoji: '❤️', label: '在一起天数', value: `${daysTogether} 天`, highlight: true },
            { emoji: '🌹', label: '开始日期', value: '2026-01-14' },
            { emoji: '💌', label: '我爱你', value: '无数次' },
            { emoji: '🎯', label: '永远爱你', value: '100%' },
            { emoji: '✨', label: '想你次数', value: '∞' },
            { emoji: '🎉', label: '幸福指数', value: '爆表' },
          ].map((s, i) => (
            <Col span={12} key={i}>
              <div style={{
                background: s.highlight ? 'linear-gradient(135deg, rgba(255,107,157,0.15), rgba(255,200,220,0.2))' : 'rgba(255,255,255,0.6)',
                borderRadius: 16, padding: '16px 12px', textAlign: 'center',
                border: s.highlight ? '2px solid rgba(255,107,157,0.3)' : '1px solid rgba(255,107,157,0.1)',
                position: 'relative', overflow: 'hidden'
              }}>
                <div style={{ fontSize: 28, marginBottom: 4 }}>{s.emoji}</div>
                <div style={{ fontSize: 18, fontWeight: 800, color: s.highlight ? '#e91e63' : '#ff6b9d' }}>{s.value}</div>
                <div style={{ fontSize: 11, color: '#aaa', marginTop: 2 }}>{s.label}</div>
              </div>
            </Col>
          ))}
        </Row>
      </div>

      {/* 快捷操作 */}
      <div className="love-card" style={{ marginBottom: 20 }}>
        <h3 style={{ margin: '0 0 16px', fontSize: 16, fontWeight: 700, color: '#333' }}>⚡ 快捷操作</h3>
        <Row gutter={[12, 12]}>
          <Col span={8}>
            <div
              onClick={() => navigate('/photos')}
              style={{
                padding: '20px 12px', textAlign: 'center', borderRadius: 16,
                background: 'rgba(255,240,246,0.6)', cursor: 'pointer',
                border: '1px solid rgba(255,107,157,0.15)', transition: 'all 0.3s'
              }}
              onMouseOver={(e) => { e.currentTarget.style.transform = 'translateY(-4px)'; e.currentTarget.style.boxShadow = '0 8px 24px rgba(255,107,157,0.2)'; }}
              onMouseOut={(e) => { e.currentTarget.style.transform = 'translateY(0)'; e.currentTarget.style.boxShadow = 'none'; }}
            >
              <div style={{ fontSize: 28 }}>📸</div>
              <div style={{ fontSize: 12, color: '#666', marginTop: 6 }}>照片</div>
            </div>
          </Col>
          <Col span={8}>
            <div
              onClick={() => navigate('/videos')}
              style={{
                padding: '20px 12px', textAlign: 'center', borderRadius: 16,
                background: 'rgba(255,240,246,0.6)', cursor: 'pointer',
                border: '1px solid rgba(255,107,157,0.15)', transition: 'all 0.3s'
              }}
              onMouseOver={(e) => { e.currentTarget.style.transform = 'translateY(-4px)'; e.currentTarget.style.boxShadow = '0 8px 24px rgba(255,107,157,0.2)'; }}
              onMouseOut={(e) => { e.currentTarget.style.transform = 'translateY(0)'; e.currentTarget.style.boxShadow = 'none'; }}
            >
              <div style={{ fontSize: 28 }}>🎬</div>
              <div style={{ fontSize: 12, color: '#666', marginTop: 6 }}>视频</div>
            </div>
          </Col>
          <Col span={8}>
            <div
              onClick={() => navigate('/anniversary')}
              style={{
                padding: '20px 12px', textAlign: 'center', borderRadius: 16,
                background: 'rgba(255,240,246,0.6)', cursor: 'pointer',
                border: '1px solid rgba(255,107,157,0.15)', transition: 'all 0.3s'
              }}
              onMouseOver={(e) => { e.currentTarget.style.transform = 'translateY(-4px)'; e.currentTarget.style.boxShadow = '0 8px 24px rgba(255,107,157,0.2)'; }}
              onMouseOut={(e) => { e.currentTarget.style.transform = 'translateY(0)'; e.currentTarget.style.boxShadow = 'none'; }}
            >
              <div style={{ fontSize: 28 }}>📅</div>
              <div style={{ fontSize: 12, color: '#666', marginTop: 6 }}>纪念日</div>
            </div>
          </Col>
        </Row>
      </div>

      <div style={{ textAlign: 'center' }}>
        <button
          className="love-btn love-btn-ghost"
          style={{ fontSize: 14, color: '#aaa', borderColor: 'rgba(200,200,200,0.4)' }}
          onClick={() => { localStorage.removeItem('token'); localStorage.removeItem('user'); navigate('/login', { replace: true }); }}
        >
          👋 退出登录
        </button>
      </div>
    </div>
  );
}

/* ================================================================
   APP ROOT
   ================================================================ */
export default function App() {
  return (
    <HashRouter>
      <Routes>
        <Route path="/login" element={<LoginPage />} />
        <Route path="/*" element={<AuthGuard><MainLayout /></AuthGuard>} />
      </Routes>
    </HashRouter>
  );
}
