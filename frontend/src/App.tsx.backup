/* ================================================================
   Floating Hearts
   ================================================================ */
function FloatingHearts() {
  const [hearts, setHearts] = useState<Array<{
    id: number; left: string; size: number; delay: number; duration: number; emoji: string;
  }>>([]);

  useEffect(() => {
    const emojis = ['💕', '💗', '💖', '❤️', '🩷', '🌸', '💝', '💞', '🌹', '✨'];
    const items = Array.from({ length: 18 }, (_, i) => ({
      id: i,
      left: `${(i / 18) * 95 + Math.random() * 5}%`,
      size: 12 + Math.random() * 20,
      delay: Math.random() * 15,
      duration: 10 + Math.random() * 14,
      emoji: emojis[Math.floor(Math.random() * emojis.length)],
    }));
    setHearts(items);
  }, []);

  return (
    <>
      {hearts.map((h) => (
        <span
          key={h.id}
          className="floating-heart"
          style={{
            left: h.left,
            fontSize: `${h.size}px`,
            animationDelay: `${h.delay}s`,
            animationDuration: `${h.duration}s`,
          }}
        >
          {h.emoji}
        </span>
      ))}
    </>
  );
}

/* ================================================================
   Stars Background (for login page)
   ================================================================ */
function StarsBg() {
  const stars = Array.from({ length: 80 }, (_, i) => ({
    id: i,
    left: `${Math.random() * 100}%`,
    top: `${Math.random() * 100}%`,
    size: 1 + Math.random() * 3,
    delay: Math.random() * 5,
    duration: 2 + Math.random() * 4,
  }));

  return (
    <div className="stars-bg">
      {stars.map((s) => (
        <div
          key={s.id}
          className="star"
          style={{
            left: s.left,
            top: s.top,
            width: s.size,
            height: s.size,
            animationDelay: `${s.delay}s`,
            animationDuration: `${s.duration}s`,
          }}
        />
      ))}
    </div>
  );
}

/* ================================================================
   Click Heart Effect
   ================================================================ */
function useClickHeart() {
  const [clicks, setClicks] = useState<Array<{ id: number; x: number; y: number; emoji: string }>>([]);
  const emojis = ['❤️', '💕', '💖', '🌸', '💗', '✨'];

  useEffect(() => {
    const handler = (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest('button, input, select, textarea, .ant-btn')) return;
      const id = Date.now() + Math.random();
      const emoji = emojis[Math.floor(Math.random() * emojis.length)];
      setClicks((prev) => [...prev.slice(-10), { id, x: e.clientX, y: e.clientY, emoji }]);
      setTimeout(() => setClicks((prev) => prev.filter((c) => c.id !== id)), 1200);
    };
    window.addEventListener('click', handler);
    return () => window.removeEventListener('click', handler);
  }, []);

  return (
    <>
      {clicks.map((c) => (
        <React.Fragment key={c.id}>
          <span className="click-heart" style={{ left: c.x, top: c.y }}>{c.emoji}</span>
          <span className="click-ripple" style={{ left: c.x, top: c.y }} />
        </React.Fragment>
      ))}
    </>
  );
}

/* ================================================================
   Mouse Trail Effect - 鼠标拖尾爱心
   ================================================================ */
function useMouseTrail() {
  const [trails, setTrails] = useState<Array<{ id: number; x: number; y: number }>>([]);

  useEffect(() => {
    const emojis = ['💕', '💗', '💖', '❤️', '🩷', '✨'];
    let lastTime = 0;
    const throttleMs = 80;

    const handler = (e: MouseEvent) => {
      const now = Date.now();
      if (now - lastTime < throttleMs) return;
      if ((e.target as HTMLElement).closest('button, input, select, textarea, .ant-btn')) return;
      lastTime = now;

      const id = now + Math.random();
      setTrails((prev) => [...prev.slice(-15), { id, x: e.clientX, y: e.clientY }]);
      setTimeout(() => setTrails((prev) => prev.filter((t) => t.id !== id)), 1000);
    };

    window.addEventListener('mousemove', handler);
    return () => window.removeEventListener('mousemove', handler);
  }, []);

  return (
    <>
      {trails.map((t) => (
        <span
          key={t.id}
          style={{
            position: 'fixed',
            left: t.x,
            top: t.y,
            pointerEvents: 'none',
            zIndex: 9997,
            fontSize: '14px',
            animation: 'heartFloat 1s ease-out forwards',
            opacity: 0.8,
          }}
        >
          💕
        </span>
      ))}
    </>
  );
}

/* ================================================================
   Keyboard L Key - 满屏爱心飘落
   ================================================================ */
function useFullScreenHearts() {
  const [hearts, setHearts] = useState<Array<{ id: number; x: number; emoji: string }>>([]);

  useEffect(() => {
    const handler = (e: KeyboardEvent) => {
      if (e.key.toLowerCase() === 'l' && !e.ctrlKey && !e.metaKey) {
        const emojis = ['❤️', '💕', '💖', '💗', '🌸', '💝', '🩷', '✨'];
        const newHearts = Array.from({ length: 50 }, (_, i) => ({
          id: Date.now() + i,
          x: Math.random() * 100,
          emoji: emojis[Math.floor(Math.random() * emojis.length)],
        }));
        setHearts((prev) => [...prev, ...newHearts]);
        setTimeout(() => {
          setHearts((prev) => prev.filter((h) => !newHearts.find((n) => n.id === h.id)));
        }, 5000);
      }
    };

    window.addEventListener('keydown', handler);
    return () => window.removeEventListener('keydown', handler);
  }, []);

  return (
    <>
      {hearts.map((h) => (
        <span
          key={h.id}
          style={{
            position: 'fixed',
            left: `${h.x}%`,
            top: '-50px',
            pointerEvents: 'none',
            zIndex: 9996,
            fontSize: `${20 + Math.random() * 30}px`,
            animation: `heartFloat ${3 + Math.random() * 2}s ease-out forwards`,
          }}
        >
          {h.emoji}
        </span>
      ))}
    </>
  );
}

/* ================================================================
   Floating Hearts Background
   ================================================================ */
function FloatingHearts() {
function AuthGuard({ children }: { children: React.ReactNode }) {
  const token = localStorage.getItem('token');
  const navigate = useNavigate();
  useEffect(() => {
    if (!token) navigate('/login', { replace: true });
  }, [token, navigate]);
  if (!token) return null;
  return <>{children}</>;
}

/* ================================================================
   LOGIN PAGE — 极致浪漫星空主题
   ================================================================ */
function LoginPage() {
  const [isRegister, setIsRegister] = useState(false);
  const [loading, setLoading] = useState(false);
  const navigate = useNavigate();

  const onFinish = async (values: any) => {
    setLoading(true);
    try {
      const endpoint = isRegister ? '/auth/register' : '/auth/login';
      const res = await apiFetch(endpoint, { method: 'POST', body: JSON.stringify(values) });
      if (res.code === 200 || res.code === 201) {
        if (res.data?.token) {
          localStorage.setItem('token', res.data.token);
          localStorage.setItem('user', JSON.stringify(res.data.user));
        }
        message.success(isRegister ? '注册成功！欢迎来到我们的小世界 💕' : '欢迎回来，我最爱的人 💖');
        navigate('/');
      } else {
        message.error(res.message || '操作失败');
      }
    } catch (e: any) {
      if (e.message === 'NETWORK_ERROR') {
        message.error('网络连接失败，请检查网络后重试');
      } else if (e.message === 'Unauthorized') {
        message.error('用户名或密码错误');
      } else {
        message.error('操作失败，请重试');
      }
    }
    setLoading(false);
  };

  return (
    <div style={{
      minHeight: '100vh', display: 'flex', alignItems: 'center', justifyContent: 'center',
      padding: 20, position: 'relative', overflow: 'hidden',
      background: 'linear-gradient(135deg, #0d001a 0%, #1a0033 20%, #330055 45%, #6b1860 70%, #c2185b 100%)',
    }}>
      <StarsBg />
      <FloatingHearts />

      {/* 动态光斑 */}
      <div style={{
        position: 'fixed', top: '15%', left: '8%', width: 350, height: 350, borderRadius: '50%',
        background: 'radial-gradient(circle, rgba(255,107,157,0.15), transparent 70%)',
        pointerEvents: 'none', filter: 'blur(50px)', animation: 'floatSide 8s ease-in-out infinite',
      }} />
      <div style={{
        position: 'fixed', bottom: '15%', right: '8%', width: 280, height: 280, borderRadius: '50%',
        background: 'radial-gradient(circle, rgba(168,85,247,0.18), transparent 70%)',
        pointerEvents: 'none', filter: 'blur(50px)', animation: 'floatSide 10s ease-in-out infinite reverse',
      }} />
      <div style={{
        position: 'fixed', top: '50%', left: '50%', transform: 'translate(-50%, -50%)', width: 500, height: 500, borderRadius: '50%',
        background: 'radial-gradient(circle, rgba(255,45,120,0.08), transparent 60%)',
        pointerEvents: 'none', filter: 'blur(60px)',
      }} />

      <div style={{
        width: '100%', maxWidth: 420, zIndex: 1,
        animation: 'scaleIn 0.6s cubic-bezier(0.34, 1.3, 0.64, 1)',
      }}>
        {/* Logo 区域 */}
        <div style={{ textAlign: 'center', marginBottom: 28 }}>
          <div style={{
            fontSize: 64, animation: 'heartBeat 2s ease-in-out infinite', display: 'inline-block',
            filter: 'drop-shadow(0 0 30px rgba(255,107,157,0.8))',
          }}>💖</div>
          <div style={{
            fontSize: 32, fontWeight: 900, letterSpacing: 4, marginTop: 8,
            background: 'linear-gradient(135deg, #fff 0%, #ffd6e7 30%, #ff9a9e 60%, #ff6b9d 100%)',
            WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent',
            backgroundClip: 'text',
          }}>
            Love For YJH
          </div>
          <div style={{
            color: 'rgba(255,200,220,0.6)', fontSize: 15, marginTop: 6,
            letterSpacing: 2, fontStyle: 'italic',
          }}>
            阳婧欢，我永远爱你 ✨
          </div>
          {/* 装饰线 */}
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 12, marginTop: 16 }}>
            <div style={{ width: 60, height: 1, background: 'linear-gradient(to right, transparent, rgba(255,107,157,0.5))' }} />
            <span style={{ fontSize: 16 }}>💕</span>
            <div style={{ width: 60, height: 1, background: 'linear-gradient(to left, transparent, rgba(255,107,157,0.5))' }} />
          </div>
        </div>

        {/* 登录卡片 */}
        <div style={{
          background: 'rgba(255,255,255,0.06)',
          backdropFilter: 'blur(30px)',
          WebkitBackdropFilter: 'blur(30px)',
          borderRadius: 24,
          border: '1px solid rgba(255,255,255,0.12)',
          padding: '36px 32px 32px',
          boxShadow: '0 40px 100px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05) inset, 0 1px 0 rgba(255,255,255,0.1) inset',
          position: 'relative', overflow: 'hidden',
        }}>
          {/* 卡片顶部光效 */}
          <div style={{
            position: 'absolute', top: 0, left: '10%', right: '10%', height: 1,
            background: 'linear-gradient(to right, transparent, rgba(255,107,157,0.4), transparent)',
